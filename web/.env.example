# =============================================================================
# KSeF Web App - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Azure Entra ID (formerly Azure AD) - Authentication
# -----------------------------------------------------------------------------
# Required for user authentication via MSAL

# Application (client) ID from Azure Entra ID app registration
NEXT_PUBLIC_AZURE_CLIENT_ID=your-azure-client-id-guid

# Directory (tenant) ID from Azure Entra ID
NEXT_PUBLIC_AZURE_TENANT_ID=your-azure-tenant-id-guid

# Optional: Custom redirect URI (default: http://localhost:3000)
# NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# URL of the Azure Functions API

# Local development (Azure Functions running locally)
NEXT_PUBLIC_API_URL=http://localhost:7071/api

# Production (Azure Static Web App with linked Functions)
# NEXT_PUBLIC_API_URL=/api

# Standalone Azure Functions deployment
# NEXT_PUBLIC_API_URL=https://your-function-app.azurewebsites.net/api

# -----------------------------------------------------------------------------
# Optional: API Scopes (for custom Azure AD API registration)
# -----------------------------------------------------------------------------
# If your API is registered in Azure AD with custom scopes
# NEXT_PUBLIC_API_SCOPE=api://your-api-client-id/.default

# =============================================================================
# dvlp-ksef Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# =============================================================================
# Azure Authentication (Entra ID)
# =============================================================================
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# =============================================================================
# Dataverse Configuration
# =============================================================================
DATAVERSE_URL=https://your-org.crm4.dynamics.com
DATAVERSE_ENTITY_INVOICES=ksef_invoices
# Extended only:
# DATAVERSE_ENTITY_TENANTS=ksef_tenants

# =============================================================================
# Azure Key Vault (for KSeF tokens)
# =============================================================================
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net

# =============================================================================
# KSeF Configuration (MVP - single tenant)
# =============================================================================
# Environment: test | demo | prod
KSEF_ENVIRONMENT=test

# Your company NIP (10 digits, no dashes)
KSEF_NIP=1234567890

# Token secret name in Key Vault
KSEF_TOKEN_SECRET_NAME=ksef-token-primary

# Token expiry date (for UI warnings)
KSEF_TOKEN_EXPIRY=2026-02-15

# =============================================================================
# Azure OpenAI (Extended - AI categorization)
# =============================================================================
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# =============================================================================
# Security Groups (Entra ID) - Authorization
# =============================================================================
# Object IDs of security groups for role-based access
# Create groups in Entra ID: DVLP-KSeF-Administrators, DVLP-KSeF-Users

# Administrators group - full access (sync, settings, delete)
NEXT_PUBLIC_ADMIN_GROUP=your-admin-group-object-id

# Users group - read-only access (view invoices, reports, export)
NEXT_PUBLIC_USER_GROUP=your-user-group-object-id

# =============================================================================
# Feature Flags
# =============================================================================
# Enable AI categorization (Extended feature)
FEATURE_AI_CATEGORIZATION=false

# Enable multi-tenant support (Extended feature)
FEATURE_MULTI_TENANT=false

# Enable export functionality (Extended feature)
FEATURE_EXPORT=false

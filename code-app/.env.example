# ─── Azure Functions API ──────────────────────────────────────────
# Base URL of the KSeF Azure Functions API
VITE_API_BASE_URL=https://ksef-api.azurewebsites.net

# ─── Azure Entra ID (authentication) ─────────────────────────────
# Entra ID App Registration client ID
VITE_AZURE_CLIENT_ID=
# Entra ID tenant ID
VITE_AZURE_TENANT_ID=
# API scope for token acquisition (e.g. api://3d2a67c9-.../access_as_user)
VITE_API_SCOPE=

# ─── Security Groups (optional RBAC) ─────────────────────────────
# Entra ID group ID for Admin role
VITE_ADMIN_GROUP=
# Entra ID group ID for User role
VITE_USER_GROUP=

# Production environment variables for Azure deployment
# These values will be baked into the build

# API URL for rewrites in next.config.mjs
API_URL=https://YOUR_FUNCTION_APP.azurewebsites.net

# Public API URL for client-side code
NEXT_PUBLIC_API_URL=https://YOUR_FUNCTION_APP.azurewebsites.net

# Azure Entra ID (formerly Azure AD) - Authentication
NEXT_PUBLIC_AZURE_CLIENT_ID=YOUR_CLIENT_ID
NEXT_PUBLIC_AZURE_TENANT_ID=YOUR_TENANT_ID

# Security Groups (Entra ID) - Authorization
NEXT_PUBLIC_ADMIN_GROUP=YOUR_ADMIN_GROUP_ID
NEXT_PUBLIC_USER_GROUP=YOUR_USER_GROUP_ID

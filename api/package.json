{
  "name": "@dvlp-ksef/api",
  "version": "0.1.0",
  "description": "Azure Functions API for KSeF integration",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc && npm run copy-prompts",
    "copy-prompts": "node -e \"const fs=require('fs');const path=require('path');const src='src/lib/prompts';const dest='dist/src/lib/prompts';fs.readdirSync(src).filter(f=>f.endsWith('.prompt.md')).forEach(f=>{fs.mkdirSync(dest,{recursive:true});fs.copyFileSync(path.join(src,f),path.join(dest,f));console.log('Copied:',f)})\"",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "dev": "npm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@azure/identity": "^4.4.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "@azure/msal-node": "^5.0.3",
    "fast-xml-parser": "^5.3.4",
    "jose": "^6.1.3",
    "openai": "^6.17.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "azure-functions-core-tools": "^4.0.6280",
    "dotenv": "^17.2.3",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
